---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import ContentTypeBadge from "../components/ContentTypeBadge.astro";
import { contentTypes, contentTypeMeta, type ContentType } from "../lib/content-types";

const title = "Realty Efficiency Hub";
const description = "AI and automation systems for modern real estate teams, with solution pages, workflow guides, and prompt libraries.";

const cleanSlug = (id: string) => id.replace(/\.md$/, "");

const posts = await getCollection("blog");
const activeTypes = contentTypes.filter((type) =>
  posts.some((post) => post.data.contentType === type)
);

const typePathMap: Record<ContentType, string> = {
  "prompt-guide": "/prompt-guides/",
  "workflow-guide": "/workflow-guides/",
  "system-guide": "/system-guides/",
  "comparison-article": "/comparison-articles/",
  guide: "/guides/",
  "tool-review": "/tool-reviews/",
};

const latestPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const solutions = [
  {
    title: "Lead Follow-Up Automation",
    href: "/solutions/real-estate-lead-follow-up-automation/",
    description:
      "For teams that need faster speed-to-lead, clearer handoff, and more consistent multi-channel follow-up.",
  },
  {
    title: "CRM Automation",
    href: "/solutions/real-estate-crm-automation/",
    description:
      "For teams that want cleaner routing, stage management, and less manual CRM overhead.",
  },
  {
    title: "Marketing Automation",
    href: "/solutions/real-estate-marketing-automation/",
    description:
      "For teams that need campaign execution, nurture timing, and reporting connected to real pipeline outcomes.",
  },
];
---

<MainLayout title={title} description={description}>

<section class="hero">
  <div class="eyebrow">Real Estate AI and Automation</div>
  <h1>Build Faster Follow-Up, Cleaner CRM Systems, and More Reliable Marketing Workflows</h1>

  <p class="hero-copy">
    Realty Efficiency Hub helps modern real estate teams understand and implement
    the AI prompts, automation workflows, and operating systems that reduce manual work
    and improve execution quality.
  </p>

  <div class="hero-actions">
    <a href="/solutions/" class="primary-cta">Explore Solutions</a>
    <a href="/start-here/" class="secondary-cta">Browse by Content Type</a>
  </div>
</section>

<section class="solutions-section">
  <h2>Start With the Problem You Need Solved</h2>
  <div class="solutions-grid">
    {solutions.map((solution) => (
      <article class="solution-card">
        <h3><a href={solution.href}>{solution.title}</a></h3>
        <p>{solution.description}</p>
      </article>
    ))}
  </div>
  <div class="solutions-cta-wrap">
    <a href="/solutions/" class="solutions-cta">View All Solutions</a>
  </div>
</section>

<section class="content-types-section">
  <h2>Navigate by Content Type</h2>
  <div class="content-grid">
    {activeTypes.map((type) => (
      <a
        href={typePathMap[type]}
        class="content-type-card"
      >
        {contentTypeMeta[type].label}
      </a>
    ))}
  </div>
</section>


<section class="latest-section">
  <h2>Latest Articles</h2>

  <div class="latest-grid">
    {latestPosts.map((post) => (
      <article class="latest-card">
        <div class="latest-top">
          <ContentTypeBadge type={post.data.contentType as ContentType} compact={true} />
        </div>
        <h3 class="latest-title">
          <a
            href={`/blog/${cleanSlug(post.id)}/`}
            class="latest-link"
          >
            {post.data.title}
          </a>
        </h3>

        <p class="latest-description">
          {post.data.description}
        </p>
      </article>
    ))}
  </div>
</section>

<style>
  .hero,
  .solutions-section,
  .content-types-section,
  .latest-section {
    max-width: 940px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero {
    padding: 34px 0 10px;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 14px;
    padding: 6px 12px;
    border-radius: 999px;
    background: #eef4ff;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  h1 {
    margin: 0 0 18px 0;
    font-size: 52px;
    line-height: 1.05;
    color: #0f172a;
    max-width: 880px;
  }

  .hero-copy {
    margin: 0;
    max-width: 820px;
    font-size: 20px;
    line-height: 1.75;
    color: #475569;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 28px;
  }

  .primary-cta,
  .secondary-cta {
    padding: 14px 20px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
  }

  .primary-cta {
    background: #2563eb;
    color: #ffffff;
    box-shadow: 0 12px 24px rgba(37, 99, 235, 0.22);
  }

  .secondary-cta {
    background: #ffffff;
    color: #0f172a;
    border: 1px solid #dbe4ee;
  }

  .solutions-section,
  .content-types-section,
  .latest-section {
    margin-top: 42px;
  }

  h2 {
    margin: 0 0 18px 0;
    font-size: 32px;
    color: #0f172a;
  }

  .solutions-grid,
  .content-grid,
  .latest-grid {
    display: grid;
    gap: 18px;
  }

  .solutions-grid,
  .content-grid {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .solution-card,
  .latest-card,
  .content-type-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
  }

  .solution-card,
  .latest-card {
    padding: 22px;
  }

  .solution-card h3,
  .latest-title {
    margin: 0 0 10px 0;
    font-size: 24px;
    line-height: 1.3;
  }

  .solution-card h3 a,
  .latest-link {
    color: #1e293b;
    text-decoration: none;
  }

  .solution-card h3 a:hover,
  .latest-link:hover,
  .content-type-card:hover {
    color: #2563eb;
  }

  .solution-card p,
  .latest-description {
    margin: 0;
    color: #475569;
    line-height: 1.7;
    font-size: 17px;
  }

  .solutions-cta-wrap {
    display: flex;
    margin-top: 18px;
  }

  .solutions-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 18px 22px;
    border-radius: 18px;
    background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
    color: #ffffff;
    text-decoration: none;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: 0.01em;
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .solutions-cta:hover {
    background: linear-gradient(135deg, #172554 0%, #2563eb 100%);
  }

  .content-type-card {
    padding: 18px;
    text-decoration: none;
    color: #1e293b;
    font-weight: 700;
  }

  .latest-top {
    margin-bottom: 8px;
  }

  @media (max-width: 720px) {
    h1 {
      font-size: 40px;
    }

    .hero-copy {
      font-size: 18px;
    }

    h2 {
      font-size: 28px;
    }
  }
</style>

</MainLayout>
