---
import MainLayout from "../layouts/MainLayout.astro";

const title = "About | Realty Efficiency Hub";
const description = "About Realty Efficiency Hub and our mission to help real estate professionals with AI and automation.";
---

<MainLayout title={title} description={description}>
  <section style="max-width: 800px; margin: 0 auto;">

    <h1 style="font-size:40px;">About</h1>

    <p style="font-size:18px; line-height:1.7; color:#475569;">
      Realty Efficiency Hub explores how artificial intelligence and automation
      can transform the daily work of real estate professionals.
    </p>

    <p style="font-size:18px; line-height:1.7; color:#475569;">
      Our goal is simple: identify the tools, workflows, and systems that help
      real estate teams operate more efficiently and close more deals while
      saving time.
    </p>

    <p style="font-size:18px; line-height:1.7; color:#475569;">
      We focus on practical insights: automation workflows, AI tools, CRM
      integrations, and operational best practices used by modern real estate
      teams.
    </p>

  </section>
</MainLayout>