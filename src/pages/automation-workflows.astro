---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import ContentTypeBadge from "../components/ContentTypeBadge.astro";
import type { ContentType } from "../lib/content-types";

const cleanSlug = (id: string) => id.replace(/\.md$/, "");

const workflowPosts = (await getCollection("blog"))
  .filter((post) => post.data.cluster === "Automation Workflows")
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<MainLayout
  title="Automation Workflows for Real Estate"
  description="Implementation-focused workflow guides for lead follow-up, qualification, open house operations, and scalable realtor systems."
>
  <section class="pillar">
    <div class="eyebrow">Cluster Hub</div>
    <h1>Automation Workflows for Real Estate Teams</h1>

    <p class="intro">
      This pillar focuses on implementation. Each article is designed as an
      operational workflow guide with clear steps, logic, and KPIs.
    </p>

    <div class="summary-box">
      <h2>Best for teams that need</h2>
      <ul>
        <li>faster speed-to-lead operations</li>
        <li>consistent qualification and routing rules</li>
        <li>repeatable follow-up execution across channels</li>
        <li>clean automation handoffs to human sales conversations</li>
      </ul>
    </div>

    <h2 class="section-title">Workflow Articles</h2>

    <div class="post-grid">
      {workflowPosts.map((post) => (
        <article class="post-card">
          <div class="card-top">
            <ContentTypeBadge type={post.data.contentType as ContentType} compact={true} />
            <p class="post-date">
              {post.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </p>
          </div>

          <h3>
            <a href={`/blog/${cleanSlug(post.id)}/`}>{post.data.title}</a>
          </h3>

          <p class="post-description">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <style>
    .pillar {
      max-width: 980px;
      margin: 0 auto;
      padding: 60px 20px;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      padding: 6px 12px;
      border-radius: 999px;
      background: #eef4ff;
      color: #1d4ed8;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    h1 {
      font-size: 48px;
      line-height: 1.1;
      margin: 0 0 20px 0;
      color: #0f172a;
    }

    .intro {
      font-size: 20px;
      line-height: 1.7;
      color: #334155;
      max-width: 820px;
      margin-bottom: 18px;
    }

    .summary-box {
      margin: 36px 0 46px 0;
      padding: 24px;
      background: #f8fbff;
      border: 1px solid #dbe4ee;
      border-radius: 18px;
    }

    .summary-box h2 {
      margin-top: 0;
      font-size: 24px;
      color: #0f172a;
    }

    .summary-box ul {
      margin: 0;
      padding-left: 20px;
      color: #334155;
      line-height: 1.8;
      font-size: 17px;
    }

    .section-title {
      font-size: 32px;
      margin: 0 0 24px 0;
      color: #0f172a;
    }

    .post-grid {
      display: grid;
      gap: 20px;
    }

    .post-card {
      background: white;
      border: 1px solid #dbe4ee;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 6px 20px rgba(15, 23, 42, 0.04);
    }

    .card-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .post-date {
      margin: 0;
      font-size: 14px;
      color: #64748b;
    }

    .post-card h3 {
      margin: 0 0 12px 0;
      font-size: 24px;
      line-height: 1.3;
    }

    .post-card h3 a {
      color: #0f172a;
      text-decoration: none;
    }

    .post-card h3 a:hover {
      color: #2563eb;
    }

    .post-description {
      margin: 0;
      font-size: 17px;
      line-height: 1.7;
      color: #475569;
    }
  </style>
</MainLayout>
