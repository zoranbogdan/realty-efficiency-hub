---
import MainLayout from "../../layouts/MainLayout.astro";

const solutions = [
  {
    title: "Real Estate Lead Follow-Up Automation",
    href: "/solutions/real-estate-lead-follow-up-automation/",
    description:
      "Design faster speed-to-lead systems with immediate acknowledgment, qualification rules, and cleaner CRM handoff.",
    outcomes: "Best for teams losing leads to slow or inconsistent follow-up.",
  },
  {
    title: "Real Estate CRM Automation",
    href: "/solutions/real-estate-crm-automation/",
    description:
      "Connect forms, routing, task creation, stage updates, and nurture logic so the CRM becomes an operating system instead of a database.",
    outcomes: "Best for teams with manual handoffs and messy pipeline operations.",
  },
  {
    title: "Real Estate Marketing Automation",
    href: "/solutions/real-estate-marketing-automation/",
    description:
      "Coordinate campaigns, segmentation, nurture timing, and conversion reporting across the channels that actually drive pipeline movement.",
    outcomes: "Best for teams that publish and promote consistently but struggle with execution reliability.",
  },
  {
    title: "Real Estate Email Automation",
    href: "/solutions/real-estate-email-automation/",
    description:
      "Build email follow-up and nurture systems that respond faster, stay personal, and support the wider follow-up workflow.",
    outcomes: "Best for teams that rely on email heavily but want more consistency and less manual drafting.",
  },
  {
    title: "Open House Lead Automation",
    href: "/solutions/open-house-lead-automation/",
    description:
      "Turn open house traffic into structured follow-up with better capture, segmentation, and next-step conversion.",
    outcomes: "Best for agents who generate lots of event traffic but lose momentum after the open house ends.",
  },
  {
    title: "Real Estate Lead Qualification Automation",
    href: "/solutions/real-estate-lead-qualification-automation/",
    description:
      "Score readiness faster, route serious opportunities more cleanly, and reduce wasted time on low-fit follow-up.",
    outcomes: "Best for teams with plenty of leads but weak clarity on who is truly ready now.",
  },
];
---

<MainLayout
  title="Solutions | Realty Efficiency Hub"
  description="Solution pages for real estate teams using AI and automation to improve lead follow-up, CRM operations, and marketing execution."
>
  <section class="shell">
    <div class="eyebrow">Solutions</div>
    <h1>Organic Landing Pages for the Problems Real Estate Teams Actually Need Solved</h1>
    <p class="intro">
      These pages translate the site&apos;s content library into clear operational themes:
      lead follow-up, CRM execution, marketing automation, email systems, open house follow-up,
      and lead qualification. Each one is built
      to support organic search intent and guide readers into the most relevant articles.
    </p>

    <div class="grid">
      {solutions.map((solution) => (
        <article class="card">
          <h2><a href={solution.href}>{solution.title}</a></h2>
          <p>{solution.description}</p>
          <p class="outcomes">{solution.outcomes}</p>
        </article>
      ))}
    </div>
  </section>

  <style>
    .shell {
      max-width: 980px;
      margin: 0 auto;
      padding: 24px 0;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      padding: 6px 12px;
      border-radius: 999px;
      background: #eef4ff;
      color: #1d4ed8;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    h1 {
      margin: 0 0 16px 0;
      font-size: 46px;
      line-height: 1.08;
      color: #0f172a;
      max-width: 920px;
    }

    .intro {
      margin: 0 0 28px 0;
      font-size: 19px;
      line-height: 1.7;
      color: #475569;
      max-width: 860px;
    }

    .grid {
      display: grid;
      gap: 18px;
    }

    .card {
      background: #ffffff;
      border: 1px solid #dbe4ee;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    h2 {
      margin: 0 0 10px 0;
      font-size: 28px;
      line-height: 1.25;
    }

    h2 a {
      text-decoration: none;
      color: #0f172a;
    }

    h2 a:hover {
      color: #2563eb;
    }

    p {
      margin: 0 0 10px 0;
      font-size: 17px;
      line-height: 1.7;
      color: #475569;
    }

    .outcomes {
      margin: 0;
      color: #1d4ed8;
      font-weight: 700;
    }

    @media (max-width: 720px) {
      h1 {
        font-size: 38px;
      }
    }
  </style>
</MainLayout>
