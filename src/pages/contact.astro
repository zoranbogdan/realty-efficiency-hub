---
import MainLayout from "../layouts/MainLayout.astro";

const subscribeEmail = "zoran@realtyefficiencyhub.com";
const subscribeSubject = encodeURIComponent("Subscribe me to Realty Efficiency Hub updates");
const subscribeBody = encodeURIComponent(
  [
    "Hi,",
    "",
    "Please subscribe me to Realty Efficiency Hub updates.",
    "",
    "Name:",
    "Email:",
  ].join("\n"),
);
---

<MainLayout
  title="Contact & Newsletter | Realty Efficiency Hub"
  description="Contact Realty Efficiency Hub and subscribe to updates about real estate AI prompts, workflows, and automation systems."
>
  <section class="contact-shell">
    <div class="hero-card">
      <div class="eyebrow">Contact & Updates</div>
      <div class="hero-grid">
        <div>
          <h1>Subscribe by Email</h1>
          <p class="intro">
            If you want updates on new prompt libraries, workflow guides, and practical real estate AI resources,
            just send a quick email and I’ll add you manually.
          </p>

          <div class="action-row">
            <a
              class="primary-link"
              href={`mailto:${subscribeEmail}?subject=${subscribeSubject}&body=${subscribeBody}`}
            >
              Email to Subscribe
            </a>
            <a class="secondary-link" href={`mailto:${subscribeEmail}`}>{subscribeEmail}</a>
          </div>

          <p class="microcopy">
            Suggested subject: <strong>Subscribe me to updates</strong>
          </p>
        </div>

        <aside class="side-card">
          <h2>What you’ll get</h2>
          <ul>
            <li>Prompt library updates</li>
            <li>New workflow guides</li>
            <li>Useful real estate AI resources</li>
            <li>No complicated signup flow</li>
          </ul>
        </aside>
      </div>
    </div>

    <section class="info-card">
      <h2>What to include</h2>
      <p class="section-intro">
        To make it easy, include your name and the email address where you want updates delivered.
      </p>

      <div class="example-card">
        <p class="example-label">Example email</p>
        <pre><code>Subject: Subscribe me to updates

Hi,

Please subscribe me to Realty Efficiency Hub updates.

Name: Your Name
Email: you@example.com</code></pre>
      </div>
    </section>
  </section>

  <style>
    .contact-shell {
      max-width: 980px;
      margin: 0 auto;
      padding: 24px 0 48px;
      display: grid;
      gap: 24px;
    }

    .hero-card,
    .info-card {
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      border: 1px solid #dbe4ee;
      border-radius: 24px;
      box-shadow: 0 12px 32px rgba(15, 23, 42, 0.06);
      padding: 30px;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 14px;
      padding: 6px 12px;
      border-radius: 999px;
      background: #e0f2fe;
      color: #075985;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.9fr);
      gap: 24px;
      align-items: start;
    }

    h1 {
      margin: 0 0 16px 0;
      font-size: 48px;
      line-height: 1.08;
      color: #0f172a;
    }

    h2 {
      margin: 0 0 10px 0;
      font-size: 28px;
      line-height: 1.15;
      color: #0f172a;
    }

    .intro,
    .section-intro,
    .microcopy,
    .side-card li {
      color: #475569;
      line-height: 1.7;
    }

    .intro {
      margin: 0 0 20px 0;
      font-size: 19px;
      max-width: 700px;
    }

    .action-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 12px;
    }

    .primary-link,
    .secondary-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      padding: 0 18px;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 800;
    }

    .primary-link {
      background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
      color: #ffffff;
      box-shadow: 0 16px 32px rgba(29, 78, 216, 0.18);
    }

    .secondary-link {
      border: 1px solid #bfdbfe;
      background: #eff6ff;
      color: #1d4ed8;
    }

    .side-card {
      background: #0f172a;
      color: #f8fafc;
      border-radius: 20px;
      padding: 24px;
    }

    .side-card h2,
    .side-card ul,
    .side-card li {
      color: inherit;
    }

    .side-card ul {
      margin: 0;
      padding-left: 20px;
    }

    .example-card {
      margin-top: 18px;
      border: 1px solid #dbe4ee;
      border-radius: 18px;
      background: #ffffff;
      padding: 18px;
    }

    .example-label {
      margin: 0 0 10px 0;
      color: #0f172a;
      font-weight: 800;
    }

    pre {
      margin: 0;
      white-space: pre-wrap;
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 14px;
      line-height: 1.7;
      color: #0f172a;
    }

    @media (max-width: 760px) {
      .hero-grid {
        grid-template-columns: 1fr;
      }

      .hero-card,
      .info-card {
        padding: 22px;
      }

      h1 {
        font-size: 38px;
      }

      h2 {
        font-size: 24px;
      }
    }
  </style>
</MainLayout>
