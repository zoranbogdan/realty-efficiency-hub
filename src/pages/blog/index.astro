---
import { getCollection } from "astro:content";
import MainLayout from "../../layouts/MainLayout.astro";

const posts = await getCollection("blog");
const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const title = "Blog | Realty Efficiency Hub";
const description = "Articles about AI, automation, and workflows for real estate teams.";
---

<MainLayout title={title} description={description}>
  <section style="max-width: 900px; margin: 0 auto;">
    <h1 style="font-size: 40px; margin-bottom: 12px;">Blog</h1>

    <p style="font-size: 18px; color: #475569; margin-bottom: 32px;">
      Insights, tools, and practical automation ideas for modern real estate teams.
    </p>

    <div style="display: grid; gap: 20px;">
      {sortedPosts.map((post) => (
        <article
          style="background:white; border:1px solid #e2e8f0; border-radius:12px; padding:24px;"
        >
          <p style="font-size: 14px; color: #64748b; margin: 0 0 10px 0;">
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </p>

          <h2 style="margin: 0 0 12px 0;">
            <a
              href={`/blog/${post.slug}`}
              style="color:#1e293b; text-decoration:none;"
            >
              {post.data.title}
            </a>
          </h2>

          <p style="margin: 0; color:#475569; line-height:1.7;">
            {post.data.description}
          </p>
        </article>
      ))}
    </div>
  </section>
</MainLayout>