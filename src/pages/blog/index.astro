---
import MainLayout from "../../layouts/MainLayout.astro";

const title = "Blog | Realty Efficiency Hub";
const description = "Articles about AI, automation, and workflows for real estate teams.";
---

<MainLayout title={title} description={description}>
  <section style="max-width: 900px; margin: 0 auto;">
    <h1 style="font-size: 40px; margin-bottom: 12px;">Blog</h1>
    <p style="font-size: 18px; color: #475569;">
      Insights, tools, and practical automation ideas for modern real estate teams.
    </p>

    <div
      style="background:white; border:1px solid #e2e8f0; border-radius:12px; padding:24px; margin-top:28px;"
    >
      <h2 style="margin-top:0;">First article coming soon</h2>
      <p>This is where your first AI and automation articles will appear.</p>
      <a href="/" style="color:#2563eb; text-decoration:none; font-weight:600;">Back to home</a>
    </div>
  </section>
</MainLayout>