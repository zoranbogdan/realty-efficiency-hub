---
import MainLayout from "../layouts/MainLayout.astro";

const title = "AI Prompts for Real Estate | Realty Efficiency Hub";
const description = "Discover practical AI prompts for real estate agents, brokers, and property teams. Improve listings, follow-ups, marketing, and client communication.";
---

<MainLayout title={title} description={description}>

<section style="max-width:900px;margin:auto;">

<h1 style="font-size:40px;margin-bottom:20px;">
AI Prompts for Real Estate Professionals
</h1>

<p style="font-size:18px;color:#475569;line-height:1.7;">
Artificial intelligence tools like ChatGPT are quickly becoming part of the
modern real estate workflow. The right prompts can help agents write better
listing descriptions, respond to leads faster, create marketing content, and
stay organized.
</p>

<p style="font-size:18px;color:#475569;line-height:1.7;">
This page collects practical AI prompts that real estate professionals can use
in daily work. Each prompt category focuses on a specific task in the real
estate process.
</p>

<h2 style="margin-top:40px;">Popular Prompt Categories</h2>

<div style="margin-top:25px;display:grid;gap:20px;">

<div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
<h3>Listing Description Prompts</h3>
<p>Create compelling property descriptions for MLS listings and property
marketing.</p>
</div>

<div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
<h3>Lead Follow-Up Prompts</h3>
<p>Respond quickly to new inquiries and maintain consistent communication with
buyers and sellers.</p>
</div>

<div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
<h3>Open House Prompts</h3>
<p>Generate follow-up messages and marketing materials for open house events.</p>
</div>

<div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
<h3>Real Estate Marketing Prompts</h3>
<p>Create social media posts, property marketing campaigns, and newsletters.</p>
</div>

</div>

</section>

</MainLayout>