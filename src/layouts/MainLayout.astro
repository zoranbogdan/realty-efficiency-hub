---
const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />

    <style>
      :root {
        --bg: #f5f7fb;
        --panel: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --line: #dbe4ee;
        --brand: #1d4ed8;
      }

      body {
        font-family: "Avenir Next", "Segoe UI", "Inter", system-ui, -apple-system, sans-serif;
        margin: 0;
        background:
          radial-gradient(1200px 500px at 15% -10%, #dbeafe 0%, transparent 45%),
          radial-gradient(900px 420px at 85% -8%, #e0f2fe 0%, transparent 45%),
          var(--bg);
        color: var(--text);
      }

      header {
        position: sticky;
        top: 0;
        z-index: 30;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, #ffffff 86%, transparent);
        border-bottom: 1px solid var(--line);
        padding: 14px 24px;
        transition: transform 0.22s ease;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1100px;
        margin: auto;
        gap: 14px;
      }

      nav a {
        text-decoration: none;
        color: var(--text);
        margin-left: 8px;
        font-weight: 600;
        font-size: 14px;
        padding: 8px 10px;
        border-radius: 9px;
      }

      nav a:hover {
        background: #eff6ff;
        color: var(--brand);
      }

      .brand {
        font-weight: 800;
        font-size: 18px;
        letter-spacing: 0.01em;
        margin-left: 0;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 6px;
      }

      main {
        max-width: 1100px;
        margin: auto;
        padding: 48px 20px 64px;
      }

      @media (max-width: 760px) {
        nav {
          display: grid;
          grid-template-columns: 1fr;
          align-items: stretch;
          gap: 12px;
        }

        header {
          padding: 12px 12px;
        }

        .brand {
          display: inline-block;
          font-size: 16px;
          padding: 10px 2px;
        }

        .nav-links {
          display: grid;
          grid-template-columns: 1fr;
          gap: 8px;
          width: 100%;
        }

        .nav-links a {
          margin-left: 0;
          text-align: center;
          font-size: 16px;
          padding: 12px 8px;
          min-height: 44px;
          display: flex;
          align-items: center;
          justify-content: center;
          border: 1px solid #dbe4ee;
          background: #ffffff;
          border-radius: 10px;
        }

        .nav-links a:hover {
          border-color: #93c5fd;
        }

        .nav-links a:not(.mobile-primary) {
          display: none;
        }

        header.mobile-hidden {
          transform: translateY(-110%);
        }

        main {
          padding-top: 34px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div>
          <a href="/" class="brand">Realty Efficiency Hub</a>
        </div>

            <div class="nav-links">
              <a href="/start-here" class="mobile-primary">Start Here</a>
              <a href="/ai-prompts" class="desktop-only">AI Prompts</a>
              <a href="/automation-workflows" class="desktop-only">Automation Workflows</a>
              <a href="/about" class="desktop-only">About</a>
              <a href="/blog" class="desktop-only">Blog</a>
            </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <script>
      const header = document.querySelector("header");
      let lastY = window.scrollY;

      const onScroll = () => {
        if (!header || window.innerWidth > 760) return;

        const y = window.scrollY;
        const scrollingDown = y > lastY;

        if (y < 40 || !scrollingDown) {
          header.classList.remove("mobile-hidden");
        } else if (scrollingDown && y > 80) {
          header.classList.add("mobile-hidden");
        }

        lastY = y;
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", () => {
        if (window.innerWidth > 760) {
          header?.classList.remove("mobile-hidden");
        }
      });
    </script>
  </body>
</html>
