---
const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />

    <style>
      body {
        font-family: system-ui, -apple-system, Arial, sans-serif;
        margin: 0;
        background: #f8fafc;
        color: #1e293b;
      }

      header {
        background: white;
        border-bottom: 1px solid #e2e8f0;
        padding: 20px 40px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1100px;
        margin: auto;
      }

      nav a {
        text-decoration: none;
        color: #1e293b;
        margin-left: 20px;
      }

      main {
        max-width: 1100px;
        margin: auto;
        padding: 60px 20px;
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div>
          <a href="/"><strong>Realty Efficiency Hub</strong></a>
        </div>

            <div>
              <a href="/about">About</a>
              <a href="/blog">Blog</a>
            </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>