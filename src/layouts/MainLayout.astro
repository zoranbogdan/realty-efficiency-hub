---
const { title, description } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" />

    <style>
      :root {
        --bg: #f5f7fb;
        --panel: #ffffff;
        --text: #0f172a;
        --muted: #475569;
        --line: #dbe4ee;
        --brand: #1d4ed8;
      }

      body {
        font-family: "Avenir Next", "Segoe UI", "Inter", system-ui, -apple-system, sans-serif;
        margin: 0;
        background:
          radial-gradient(1200px 500px at 15% -10%, #dbeafe 0%, transparent 45%),
          radial-gradient(900px 420px at 85% -8%, #e0f2fe 0%, transparent 45%),
          var(--bg);
        color: var(--text);
      }

      header {
        position: sticky;
        top: 0;
        z-index: 30;
        backdrop-filter: blur(8px);
        background: color-mix(in srgb, #ffffff 86%, transparent);
        border-bottom: 1px solid var(--line);
        padding: 14px 24px;
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1100px;
        margin: auto;
      }

      nav a {
        text-decoration: none;
        color: var(--text);
        margin-left: 8px;
        font-weight: 600;
        font-size: 14px;
        padding: 8px 10px;
        border-radius: 9px;
      }

      nav a:hover {
        background: #eff6ff;
        color: var(--brand);
      }

      .brand {
        font-weight: 800;
        font-size: 18px;
        letter-spacing: 0.01em;
      }

      main {
        max-width: 1100px;
        margin: auto;
        padding: 48px 20px 64px;
      }

      @media (max-width: 760px) {
        nav {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }

        header {
          padding: 12px 14px;
        }

        main {
          padding-top: 34px;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <nav>
        <div>
          <a href="/" class="brand">Realty Efficiency Hub</a>
        </div>

            <div>
              <a href="/start-here">Start Here</a>
              <a href="/ai-prompts">AI Prompts</a>
              <a href="/automation-workflows">Automation Workflows</a>
              <a href="/about">About</a>
              <a href="/blog">Blog</a>
            </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>
