---
import MainLayout from "./MainLayout.astro";

const { frontmatter } = Astro.props;
---

<MainLayout title={frontmatter.title} description={frontmatter.description}>

<article class="blog-container">

  <header class="blog-header">
    <h1>{frontmatter.title}</h1>

    <div class="blog-meta">
      <span>{new Date(frontmatter.pubDate).toLocaleDateString()}</span>
    </div>

    <p class="blog-description">
      {frontmatter.description}
    </p>
  </header>

  <section class="blog-content">
    <slot />
  </section>

</article>

<style>

:root{
  --color-primary:#1E3A8A;
  --color-accent:#2563EB;
  --color-text:#0F172A;
  --color-muted:#475569;
  --color-bg:#F8FAFC;
  --color-border:#E2E8F0;
  --color-code:#EEF2FF;
}

body{
  background:var(--color-bg);
  color:var(--color-text);
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
}

.blog-container{
  max-width:760px;
  margin:0 auto;
  padding:50px 20px;
}

.blog-header h1{
  font-size:42px;
  line-height:1.2;
  margin-bottom:12px;
  color:var(--color-text);
}

.blog-meta{
  font-size:14px;
  color:var(--color-muted);
  margin-bottom:20px;
}

.blog-description{
  font-size:20px;
  line-height:1.6;
  margin-bottom:40px;
  color:var(--color-muted);
}

.blog-content h2{
  margin-top:42px;
  font-size:28px;
  color:var(--color-text);
}

.blog-content h3{
  margin-top:28px;
  font-size:22px;
}

.blog-content p{
  line-height:1.8;
  margin-bottom:20px;
  font-size:18px;
}

.blog-content a{
  color:var(--color-accent);
  text-decoration:none;
}

.blog-content a:hover{
  text-decoration:underline;
}

.blog-content ul{
  margin-left:20px;
  margin-bottom:20px;
}

.blog-content code{
  background:var(--color-code);
  padding:3px 6px;
  border-radius:6px;
}

.blog-content pre{
  background:var(--color-code);
  padding:20px;
  border-radius:10px;
  overflow-x:auto;
  margin:25px 0;
  border:1px solid var(--color-border);
}

.blog-content blockquote{
  border-left:4px solid var(--color-accent);
  padding-left:20px;
  color:var(--color-muted);
  margin:20px 0;
}

</style>

</MainLayout>